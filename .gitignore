# Xcode project is generated by XcodeGen from project.yml (`make setup`)
Vesta.xcodeproj/

# Build output
build/
DerivedData/
*.xcresult
*.xcarchive

# Swift Package Manager
.swiftpm/
.build/

# swift-openapi-generator output (build-time plugin; never committed)
**/GeneratedSources/

# Xcode user state
xcuserdata/
*.xcuserstate
*.xcscmblueprint

# Local-only backend URL override for dev tooling (live tunnel/staging)
.local-backend-url

# macOS
.DS_Store
