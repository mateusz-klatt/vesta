    "The server took too long to answer. Check Wi-Fi, VPN, or the server.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استغرق الخادم وقتًا طويلًا للرد. تحقق من Wi‑Fi أو VPN أو الخادم."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "সার্ভার উত্তর দিতে খুব বেশি সময় নিয়েছে। Wi‑Fi, VPN বা সার্ভার পরীক্ষা করুন।"
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Serveru je trebalo predugo da odgovori. Provjerite Wi‑Fi, VPN ili server."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Serveru trvala odpověď příliš dlouho. Zkontrolujte Wi‑Fi, VPN nebo server."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Serveren var for længe om at svare. Kontrollér Wi‑Fi, VPN eller serveren."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Server hat zu lange zum Antworten gebraucht. Prüfe WLAN, VPN oder den Server."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ο διακομιστής άργησε πολύ να απαντήσει. Ελέγξτε το Wi‑Fi, το VPN ή τον διακομιστή."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El servidor tardó demasiado en responder. Comprueba la Wi‑Fi, la VPN o el servidor."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "پاسخ سرور بیش از حد طول کشید. Wi‑Fi، VPN یا سرور را بررسی کنید."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Palvelimen vastaus kesti liian kauan. Tarkista Wi‑Fi, VPN tai palvelin."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Masyadong matagal sumagot ang server. Suriin ang Wi‑Fi, VPN, o ang server."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le serveur a mis trop de temps à répondre. Vérifiez le Wi‑Fi, le VPN ou le serveur."
          }
        },
        "ga": {
          "stringUnit": {
            "state": "translated",
            "value": "Thóg an freastalaí rófhada le freagairt. Seiceáil Wi‑Fi, VPN nó an freastalaí."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "לשרת לקח זמן רב מדי לענות. יש לבדוק את Wi‑Fi, את ה-VPN או את השרת."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सर्वर ने जवाब देने में बहुत समय लिया। Wi‑Fi, VPN या सर्वर जाँचें।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Poslužitelju je trebalo predugo da odgovori. Provjerite Wi‑Fi, VPN ili poslužitelj."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A szerver túl sokáig válaszolt. Ellenőrizd a Wi‑Fi-t, a VPN-t vagy a szervert."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "translated",
            "value": "Սերվերի պատասխանը չափազանց երկար տևեց։ Ստուգեք Wi‑Fi-ը, VPN-ը կամ սերվերը։"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Server terlalu lama menjawab. Periksa Wi‑Fi, VPN, atau server."
          }
        },
        "is": {
          "stringUnit": {
            "state": "translated",
            "value": "Þjónninn var of lengi að svara. Athugaðu Wi‑Fi, VPN eða þjóninn."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il server ha impiegato troppo tempo a rispondere. Controlla Wi‑Fi, VPN o il server."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サーバーの応答に時間がかかりすぎました。Wi‑Fi、VPN、またはサーバーを確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "서버가 응답하는 데 너무 오래 걸렸습니다. Wi‑Fi, VPN 또는 서버를 확인하십시오."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Serveris atsakinėjo per ilgai. Patikrinkite Wi‑Fi, VPN arba serverį."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Serveris atbildēja pārāk ilgi. Pārbaudiet Wi‑Fi, VPN vai serveri."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pelayan mengambil masa terlalu lama untuk menjawab. Semak Wi‑Fi, VPN atau pelayan."
          }
        },
        "my": {
          "stringUnit": {
            "state": "translated",
            "value": "ဆာဗာတုံ့ပြန်ရန် အချိန်ကြာလွန်းသည်။ Wi‑Fi၊ VPN သို့မဟုတ် ဆာဗာကို စစ်ဆေးပါ။"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Serveren brukte for lang tid på å svare. Kontroller Wi‑Fi, VPN eller serveren."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De server deed er te lang over om te antwoorden. Controleer wifi, VPN of de server."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Serwer odpowiadał zbyt długo. Sprawdź Wi‑Fi, VPN lub serwer."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O servidor demorou demais para responder. Verifique o Wi‑Fi, a VPN ou o servidor."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Serverul a răspuns prea greu. Verifică Wi‑Fi, VPN-ul sau serverul."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сервер слишком долго отвечал. Проверьте Wi‑Fi, VPN или сервер."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Serveru trvala odpoveď príliš dlho. Skontrolujte Wi‑Fi, VPN alebo server."
          }
        },
        "sq": {
          "stringUnit": {
            "state": "translated",
            "value": "Serveri vonoi shumë për t’u përgjigjur. Kontrollo Wi‑Fi, VPN ose serverin."
          }
        },
        "sr-Latn": {
          "stringUnit": {
            "state": "translated",
            "value": "Serveru je trebalo predugo da odgovori. Proverite Wi‑Fi, VPN ili server."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Servern tog för lång tid på sig att svara. Kontrollera Wi‑Fi, VPN eller servern."
          }
        },
        "sw": {
          "stringUnit": {
            "state": "translated",
            "value": "Seva ilichukua muda mrefu sana kujibu. Angalia Wi‑Fi, VPN au seva."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เซิร์ฟเวอร์ตอบกลับช้าเกินไป ตรวจสอบ Wi‑Fi, VPN หรือเซิร์ฟเวอร์"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sunucunun yanıt vermesi çok uzun sürdü. Wi‑Fi, VPN veya sunucuyu kontrol edin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Сервер відповідав надто довго. Перевірте Wi‑Fi, VPN або сервер."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Máy chủ phản hồi quá lâu. Kiểm tra Wi‑Fi, VPN hoặc máy chủ."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "服务器响应时间过长。请检查 Wi‑Fi、VPN 或服务器。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "伺服器回應時間過長。請檢查 Wi‑Fi、VPN 或伺服器。"
          }
        }
      }
    },
    "The server’s certificate could not be verified.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذر التحقق من شهادة الخادم."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "সার্ভারের সার্টিফিকেট যাচাই করা যায়নি।"
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Certifikat servera nije moguće provjeriti."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Certifikát serveru se nepodařilo ověřit."
          }
        },
