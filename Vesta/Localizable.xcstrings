        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Insira apenas a origem, por exemplo https://hestia.example (sem caminho). http simples é permitido para um endereço LAN."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Introduceți doar originea, de ex. https://hestia.example (fără cale). http simplu este permis pentru o adresă LAN."
