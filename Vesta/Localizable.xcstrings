          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A szerver tanúsítványát nem sikerült ellenőrizni."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "translated",
            "value": "Սերվերի վկայագիրը հնարավոր չեղավ հաստատել։"
