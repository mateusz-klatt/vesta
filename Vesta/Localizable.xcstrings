    "Check the address and that the server is running.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تحقق من العنوان ومن أن الخادم يعمل."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "ঠিকানা এবং সার্ভার চলছে কি না যাচাই করুন।"
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Provjerite adresu i da li server radi."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zkontrolujte adresu a že server běží."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Kontrollér adressen, og at serveren kører."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Prüfe die Adresse und ob der Server läuft."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ελέγξτε τη διεύθυνση και ότι ο διακομιστής λειτουργεί."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comprueba la dirección y que el servidor esté en ejecución."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "نشانی را بررسی کنید و مطمئن شوید سرور در حال اجراست."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tarkista osoite ja että palvelin on käynnissä."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Suriin ang address at kung tumatakbo ang server."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vérifiez l’adresse et que le serveur fonctionne."
          }
        },
        "ga": {
          "stringUnit": {
            "state": "translated",
            "value": "Seiceáil an seoladh agus go bhfuil an freastalaí ag rith."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "יש לבדוק את הכתובת ושהשרת פועל."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पता जाँचें और सुनिश्चित करें कि सर्वर चल रहा है।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Provjerite adresu i radi li poslužitelj."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ellenőrizd a címet, és hogy fut-e a szerver."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "translated",
            "value": "Ստուգեք հասցեն և համոզվեք, որ սերվերը աշխատում է։"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Periksa alamat dan pastikan server berjalan."
          }
        },
        "is": {
          "stringUnit": {
            "state": "translated",
            "value": "Athugaðu vistfangið og að þjónninn sé í gangi."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Controlla l’indirizzo e che il server sia in esecuzione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アドレスとサーバーが動作していることを確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "주소와 서버가 실행 중인지 확인하십시오."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Patikrinkite adresą ir ar serveris veikia."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Pārbaudiet adresi un vai serveris darbojas."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Semak alamat dan pastikan pelayan sedang berjalan."
          }
        },
        "my": {
          "stringUnit": {
            "state": "translated",
            "value": "လိပ်စာနှင့် ဆာဗာ လုပ်ဆောင်နေကြောင်း စစ်ဆေးပါ။"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Kontroller adressen og at serveren kjører."
          }
        },
        "nl": {
