    "Your iPhone appears to be offline.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يبدو أن iPhone غير متصل بالإنترنت."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আপনার iPhone অফলাইনে আছে বলে মনে হচ্ছে।"
          }
        },
        "bs": {
