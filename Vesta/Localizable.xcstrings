    "Enter just the origin, e.g. https://hestia.example (no path). Plain http is allowed for a LAN address.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أدخل الأصل فقط، مثل https://hestia.example (بدون مسار). يُسمح باستخدام http العادي لعنوان LAN."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "শুধু origin লিখুন, যেমন https://hestia.example (পথ নয়)। LAN ঠিকানার জন্য সাধারণ http অনুমোদিত।"
          }
        },
        "bs": {
          "stringUnit": {
            "state": "translated",
            "value": "Unesite samo origin, npr. https://hestia.example (bez putanje). Obični http je dozvoljen za LAN adresu."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zadejte jen origin, např. https://hestia.example (bez cesty). Pro adresu v LAN je povolený obyčejný http."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Indtast kun origin, f.eks. https://hestia.example (ingen sti). Almindelig http er tilladt for en LAN-adresse."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gib nur den Origin ein, z. B. https://hestia.example (ohne Pfad). Für eine LAN-Adresse ist normales http zulässig."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Εισαγάγετε μόνο το origin, π.χ. https://hestia.example (χωρίς διαδρομή). Το απλό http επιτρέπεται για διεύθυνση LAN."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Introduce solo el origen, p. ej., https://hestia.example (sin ruta). Se permite http sin cifrar para una dirección LAN."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "فقط origin را وارد کنید، مثلاً https://hestia.example (بدون مسیر). برای آدرس LAN، http ساده مجاز است."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Syötä vain origin, esim. https://hestia.example (ei polkua). Tavallinen http on sallittu LAN-osoitteelle."
          }
        },
        "fil": {
          "stringUnit": {
            "state": "translated",
            "value": "Ilagay lang ang origin, hal. https://hestia.example (walang path). Pinapayagan ang plain http para sa LAN address."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Saisissez uniquement l’origine, par ex. https://hestia.example (sans chemin). Le http simple est autorisé pour une adresse LAN."
          }
        },
        "ga": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuir isteach an origin amháin, m.sh. https://hestia.example (gan chonair). Ceadaítear http simplí do sheoladh LAN."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "יש להזין רק את ה-origin, למשל https://hestia.example (ללא נתיב). מותר להשתמש ב-http רגיל עבור כתובת LAN."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सिर्फ़ origin दर्ज करें, जैसे https://hestia.example (पाथ नहीं)। LAN पते के लिए साधारण http की अनुमति है।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Unesite samo origin, npr. https://hestia.example (bez putanje). Obični http dopušten je za LAN adresu."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Csak az origint add meg, pl. https://hestia.example (útvonal nélkül). LAN-címhez a sima http is engedélyezett."
          }
        },
        "hy": {
          "stringUnit": {
            "state": "translated",
            "value": "Մուտքագրեք միայն origin-ը, օրինակ՝ https://hestia.example (առանց ուղու)։ LAN հասցեի համար թույլատրվում է սովորական http։"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Masukkan origin saja, misalnya https://hestia.example (tanpa path). http biasa diizinkan untuk alamat LAN."
          }
        },
        "is": {
          "stringUnit": {
            "state": "translated",
            "value": "Sláðu aðeins inn uppruna, t.d. https://hestia.example (engin slóð). Einfalt http er leyft fyrir LAN-vistfang."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Inserisci solo l’origine, ad es. https://hestia.example (senza percorso). Il semplice http è consentito per un indirizzo LAN."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オリジンのみを入力してください（例：https://hestia.example）。パスは不要です。LANアドレスにはプレーンなhttpを使用できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "origin만 입력하세요. 예: https://hestia.example(경로 없음). LAN 주소에는 일반 http를 사용할 수 있습니다."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Įveskite tik origin, pvz., https://hestia.example (be kelio). LAN adresui leidžiamas paprastas http."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ievadiet tikai origin, piem., https://hestia.example (bez ceļa). LAN adresei ir atļauts vienkāršs http."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Masukkan origin sahaja, cth. https://hestia.example (tanpa laluan). http biasa dibenarkan untuk alamat LAN."
          }
        },
        "my": {
          "stringUnit": {
            "state": "translated",
            "value": "origin ကိုသာ ထည့်ပါ၊ ဥပမာ https://hestia.example (လမ်းကြောင်း မပါ)။ LAN လိပ်စာအတွက် ရိုးရိုး http ကို ခွင့်ပြုထားသည်။"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Skriv bare inn origin, f.eks. https://hestia.example (ingen bane). Vanlig http er tillatt for en LAN-adresse."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voer alleen de origin in, bijv. https://hestia.example (geen pad). Gewone http is toegestaan voor een LAN-adres."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Podaj sam origin, np. https://hestia.example (bez ścieżki). Dla adresu LAN dozwolone jest zwykłe http."
          }
